# ─────────────────────────────────────────────────────────────────────────────
# SignMeet — backend environment variables
# Copy this file to .env and fill in real values.
# .env is git-ignored; this file is safe to commit.
# ─────────────────────────────────────────────────────────────────────────────

# Django
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Local dev convenience:
# Set USE_SQLITE=True to run without PostgreSQL.
USE_SQLITE=True

# PostgreSQL (only used when USE_SQLITE=False)
DB_NAME=signmeet_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# Redis (optional; leave blank to use InMemoryChannelLayer in dev)
REDIS_URL=
